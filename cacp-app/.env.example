# OpenRouter API key for 1001tracklists mix matching (also configurable in DeskThing app settings)
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional — defaults to ~/Library/Application Support/Google/Chrome/DevToolsActivePort
# CHROME_DEVTOOLS_ACTIVE_PORT_PATH=/Users/you/Library/Application Support/Google/Chrome/DevToolsActivePort

# Optional — extension WebSocket bridge port (default 8081)
# CACP_WS_PORT=8081
