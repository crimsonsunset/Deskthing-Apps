# Copy to .env and fill in values:
#   cp .env.example .env
#
# OPENROUTER_API_KEY can also be copied from set-times-app/.env if you use that project.

# Required for 1001tracklists LLM matching (server-side only)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional — defaults to ~/Library/Application Support/Google/Chrome/DevToolsActivePort
# CHROME_DEVTOOLS_ACTIVE_PORT_PATH=/Users/you/Library/Application Support/Google/Chrome/DevToolsActivePort

# Optional — extension WebSocket bridge port (default 8081)
# CACP_WS_PORT=8081
