{
  "name": "cacp",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "main": "dist/index.js",
  "description": "Chrome Audio Control Platform - Universal DeskThing app for multi-site audio control",
  "scripts": {
    "dev:vite": "vite",
    "dev:wrapper": "npx @deskthing/cli dev",
    "dev": "node scripts/run-dev.script.js",
    "build": "node scripts/stage-package-assets.script.js && npx @deskthing/cli package",
    "setup": "node setup.js",
    "lint": "eslint .",
    "test": "node --loader tsm --test server/tracklist/tracklist-scraper.test.ts",
    "test:tracklist": "node scripts/run-with-env.script.js --import=tsm server/tracklist/test-nora-512.script.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@crimsonsunset/jsg-logger": "^1.8.9",
    "@deskthing/client": "latest",
    "@deskthing/server": "latest",
    "autoprefixer": "^10.4.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "puppeteer-core": "^24.10.2",
    "ws": "^8.18.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@deskthing/cli": "^0.11.15",
    "@deskthing/types": "^0.11.9",
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.2",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "linkedom": "^0.18.12",
    "tailwindcss": "^3.4.10",
    "tsm": "^2.3.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.15"
  },
  "keywords": [
    "deskthing",
    "cacp",
    "audio-control",
    "multi-site",
    "universal"
  ]
}
